---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="About"
  description={`About ${siteConfig.site.name} — verified research and data kept current.`}
>
  <Navbar />
  <main>
    <section class="section">
      <div class="container about-layout">
        <div class="about-photo-wrap reveal">
          <img
            class="about-photo"
            src="/images/lydia.png"
            alt="Lydia Zhigmitova"
            width="120"
            height="120"
          />
        </div>
        <div class="about-copy reveal delay-1">
          <p class="eyebrow">About</p>
          <h1>{siteConfig.site.name}</h1>
          <p>{siteConfig.about.intro}</p>
          <p>
            Data goes stale fast. A price is right today and wrong next week. A contact list
            loses working emails every month. That’s not something for you to manage alone —
            it’s why careful verification and a simple monthly rhythm matter.
          </p>
          <p>{siteConfig.about.experience}</p>
        </div>
      </div>
    </section>

    <section class="section section-tight">
      <div class="container narrow">
        <h2 class="reveal">How I work</h2>
        <p class="reveal">{siteConfig.about.mission}</p>
        <ul class="values-list">
          {siteConfig.about.values.map((value) => (
            <li class="reveal">
              <strong>{value.title}</strong>
              <span>{value.description}</span>
            </li>
          ))}
        </ul>
        <div class="cta-row reveal">
          <a class="button" href="/book">Book a Consultation</a>
          <a class="button secondary" href="/services">View services</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
