---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="Services"
  description="AI-visibility audits, chatbot testing, AI help systems, document automation, and content fact-checking — five services that make AI accurate and verifiable."
>
  <Navbar />
  <main>
    <section class="section">
      <div class="container narrow">
        <p class="eyebrow reveal">Services</p>
        <h1 class="reveal">Make AI accurate, verifiable, and useful.</h1>
        <p class="section-lead reveal">
          Five services that test, structure, and verify AI systems and content — so buyers can
          find you through AI search, your assistants answer correctly, and everything you
          publish holds up to scrutiny.
        </p>
      </div>
    </section>

    <section class="section section-tight">
      <div class="container">
        <ul class="service-list">
          {siteConfig.services.map((service) => (
            <li class="service-row reveal">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <p class="for-whom">Who it's for: {service.forWhom}</p>
              <ul class="price-lines">
                {service.pricing.map((line) => (
                  <li class="price-line">
                    {line.label && <span class="price-label">{line.label}</span>}
                    <span class="price-amount">{line.value}</span>
                    {line.free && <span class="tag">Free for first clients</span>}
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section section-tight">
      <div class="container narrow">
        <p class="section-lead reveal">
          Across all five services, the goal is the same: making AI accurate, verifiable, and
          genuinely useful for your business.
        </p>
        <p class="reveal muted-note">
          I can’t guarantee inclusion in AI-generated answers, rankings, or sales — no honest
          provider can. What I do guarantee is that the work is accurate, verifiable, and
          delivered on time.
        </p>
        <div class="cta-row reveal">
          <a class="button" href="/book">Book a Consultation</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
