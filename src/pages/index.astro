---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

const posts = [
  { title: 'How to build a resilient growth strategy in 2026', href: '/blog/strategy-2026', category: 'Strategy' },
  { title: 'Three signs your operations need a reset', href: '/blog/operations-reset', category: 'Operations' },
];
---

<BaseLayout title="Home" description="Modern business strategy and advisory services for ambitious teams.">
  <Navbar />
  <main>
    <section class="hero">
      <div class="container grid hero">
        <div>
          <p class="eyebrow">{siteConfig.hero.title.substring(0, 50)}...</p>
          <h1>{siteConfig.hero.title}</h1>
          <p>{siteConfig.hero.subtitle}</p>
          <div class="pill-row">
            <a class="button" href="{siteConfig.hero.ctaLink}">{siteConfig.hero.ctaText}</a>
            <a class="button secondary" href="/services">Explore Services</a>
          </div>
        </div>
        <div class="hero-card">
          <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=900&q=80" alt="Professional consulting session" />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="pill-row">
          <span class="pill">Strategy</span>
          <span class="pill">Operations</span>
          <span class="pill">Leadership</span>
        </div>
        <div class="grid grid-3">
          {siteConfig.services.map((service) => (
            <article class="card">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>What clients say</h2>
        <div class="grid grid-2">
          {siteConfig.testimonials.map((item) => (
            <article class="card">
              <p>"{item.quote}"</p>
              <strong>{item.author}</strong>
              <p>{item.company}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>Latest insights</h2>
        <div class="grid grid-2">
          {posts.map((post) => (
            <article class="card">
              <p class="eyebrow">{post.category}</p>
              <h3>{post.title}</h3>
              <a class="button secondary" href={post.href}>Read more</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container card">
        <h2>Ready to move forward?</h2>
        <p>Let’s build a practical roadmap for your next chapter.</p>
        <a class="button" href="/contact">Get in touch</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
