---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

const highlights = siteConfig.services.slice(0, 3);
---

<BaseLayout
  title="Home"
  description={siteConfig.site.description}
>
  <Navbar />
  <main>
    <section class="hero hero-minimal">
      <div class="container hero-grid">
        <div class="hero-photo-wrap reveal">
          <img
            class="hero-photo"
            src="/images/lydia.png"
            alt="Lydia Zhigmitova"
            width="240"
            height="240"
          />
        </div>
        <div class="hero-inner">
          <p class="brand-signal reveal">{siteConfig.site.name}</p>
          <h1 class="reveal delay-1">{siteConfig.hero.title}</h1>
          <p class="hero-lead reveal delay-2">{siteConfig.hero.subtitle}</p>
          <div class="cta-row reveal delay-3">
            <a class="button" href={siteConfig.hero.ctaLink}>{siteConfig.hero.ctaText}</a>
            <a class="button secondary" href="/services">View services</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="reveal">What I do</h2>
        <p class="section-lead reveal">
          Five services that make AI reliable — from getting cited in AI search to verifying
          every claim before you publish.
        </p>
        <ul class="service-preview">
          {highlights.map((service) => (
            <li class="reveal">
              <div>
                <strong>{service.title}</strong>
                <span>{service.summary}</span>
              </div>
              <span class="price">{service.priceSummary}</span>
            </li>
          ))}
        </ul>
        <p class="reveal">
          <a class="text-link" href="/services">See all five services →</a>
        </p>
      </div>
    </section>

    <section class="section section-tight">
      <div class="container">
        <h2 class="reveal">How I keep AI honest</h2>
        <ul class="guarantee-list">
          {siteConfig.guarantees.map((item) => (
            <li class="reveal">{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section">
      <div class="container cta-block reveal">
        <h2>Ready to make your AI reliable?</h2>
        <p>Tell me what you need and how soon — I’ll reply with a clear next step.</p>
        <a class="button" href="/book">Book a Consultation</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
