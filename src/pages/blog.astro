---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Insights on strategy, operations, and leadership for growing businesses.">
  <Navbar />
  <main>
    <section class="section">
      <div class="container">
        <p class="eyebrow">Blog</p>
        <h1>Practical ideas for leaders navigating change.</h1>
        <div class="pill-row">
          <span class="pill">Strategy</span>
          <span class="pill">Operations</span>
          <span class="pill">Leadership</span>
        </div>
        <div class="grid grid-2">
          {posts.map((post) => (
            <article class="card">
              {post.data.category && <p class="eyebrow">{post.data.category}</p>}
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="blog-meta">
                {post.data.readingTime && <span class="pill">{post.data.readingTime}</span>}
                {post.data.tags.map((tag) => <span class="pill">#{tag}</span>)}
              </div>
              <a class="button secondary" href={`/blog/${post.id}`}>Read article</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
