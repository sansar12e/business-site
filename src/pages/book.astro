---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="Book Consultation"
  description="Book a consultation for verified research, lead lists, price tracking, or catalog work."
>
  <Navbar />
  <main>
    <section class="section">
      <div class="container grid grid-2 book-layout">
        <div class="reveal">
          <p class="eyebrow">Book Consultation</p>
          <h1>Tell me what you need.</h1>
          <p>
            Share a few details and I’ll follow up with a fixed quote — project pricing and,
            where it fits, what it costs to keep the work current each month.
          </p>
          <ul class="list">
            <li>Email: <a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></li>
            <li>
              LinkedIn:
              <a href={siteConfig.contact.linkedin} target="_blank" rel="noreferrer">Profile</a>
            </li>
          </ul>
        </div>
        <div class="form-panel reveal delay-1">
          <form
            action={`https://formspree.io/f/${siteConfig.contact.formspreeId}`}
            method="POST"
            class="form-grid"
          >
            <div>
              <label for="name">Name</label>
              <input id="name" name="name" placeholder="Your name" required />
            </div>
            <div>
              <label for="email">Email</label>
              <input id="email" name="email" type="email" placeholder="you@example.com" required />
            </div>
            <div>
              <label for="need">What do you need?</label>
              <input
                id="need"
                name="need"
                placeholder="Price check, lead list, research brief, catalog audit…"
                required
              />
            </div>
            <div>
              <label for="timeline">How soon?</label>
              <input id="timeline" name="timeline" placeholder="This week, next month…" />
            </div>
            <div>
              <label for="message">Anything else?</label>
              <textarea
                id="message"
                name="message"
                placeholder="Links, competitors to watch, or context that helps."
              ></textarea>
            </div>
            <button class="button" type="submit">Send request</button>
          </form>
        </div>
      </div>
    </section>

    <section class="section section-tight">
      <div class="container">
        <h2 class="reveal">Frequently asked questions</h2>
        <div class="faq-list">
          {siteConfig.faq.map((faq) => (
            <article class="faq-item reveal">
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
